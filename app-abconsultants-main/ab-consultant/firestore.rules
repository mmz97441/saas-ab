rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isConsultant() {
      return isAuthenticated() && request.auth.token.role == 'consultant';
    }

    function isAdmin() {
      return isConsultant() && request.auth.token.isAdmin == true;
    }

    function isClient() {
      return isAuthenticated() && request.auth.token.role == 'client';
    }

    function myEmail() {
      return request.auth.token.email;
    }

    // Un client a accès à un dossier si :
    //  - son custom claim clientId correspond (owner ou collaborator setup par onUserCreated)
    //  - OU son email correspond à owner.email du doc (fallback avant refresh claims)
    //  - OU son email est dans le tableau dénormalisé collaboratorEmails
    // Cette fonction fait un get() → coût de lecture supplémentaire. À utiliser hors match /clients.
    function hasClientAccess(clientId) {
      let clientData = get(/databases/$(database)/documents/clients/$(clientId)).data;
      return isAuthenticated() && (
        request.auth.token.clientId == clientId
        || clientData.owner.email == myEmail()
        || (clientData.collaboratorEmails is list && myEmail() in clientData.collaboratorEmails)
      );
    }

    // Version pour les règles dans match /clients/{clientId} où la resource est déjà le doc client
    function hasAccessToResource(clientId) {
      return isAuthenticated() && (
        request.auth.token.clientId == clientId
        || resource.data.owner.email == myEmail()
        || (resource.data.collaboratorEmails is list && myEmail() in resource.data.collaboratorEmails)
      );
    }

    // =============================================
    // CLIENTS COLLECTION
    // =============================================
    match /clients/{clientId} {
      // Lecture : consultant OU propriétaire/collaborateur du dossier uniquement
      // CORRIGÉ (audit sécurité) : l'ancienne règle permettait à TOUT utilisateur authentifié
      // de lire TOUS les clients (fuite cross-tenant critique).
      allow read: if isConsultant() || hasAccessToResource(clientId);

      // Création & modification : consultants uniquement
      allow create, update: if isConsultant();

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }

    // =============================================
    // RECORDS COLLECTION (Financial Data)
    // =============================================
    match /records/{recordId} {
      // Lecture : consultant OU client ayant accès au dossier
      allow read: if isConsultant() || hasClientAccess(resource.data.clientId);

      // Création par un client : interdit de pré-valider/publier son propre record
      // CORRIGÉ (audit sécurité) : l'ancienne règle permettait à un client de créer avec
      // isValidated: true et isPublished: true, contournant le workflow d'approbation.
      allow create: if isConsultant()
                   || (isClient()
                       && hasClientAccess(request.resource.data.clientId)
                       && request.resource.data.get('isValidated', false) == false
                       && request.resource.data.get('isPublished', false) == false
                       && !('expertComment' in request.resource.data));

      // Modification par un client : ne peut pas changer les flags consultant-only
      allow update: if isConsultant()
                   || (isClient()
                       && hasClientAccess(resource.data.clientId)
                       && request.resource.data.get('isValidated', false) == resource.data.get('isValidated', false)
                       && request.resource.data.get('isPublished', false) == resource.data.get('isPublished', false)
                       && request.resource.data.get('expertComment', '') == resource.data.get('expertComment', ''));

      // Suppression : consultants uniquement
      allow delete: if isConsultant();
    }

    // =============================================
    // CONSULTANTS COLLECTION (Team Management)
    // =============================================
    match /consultants/{consultantId} {
      // Lecture : tout utilisateur authentifié
      // TODO (audit S8) : migrer checkConsultantEmailExists vers une Cloud Function callable
      // pour restreindre cette lecture aux consultants uniquement. Actuellement utilisée
      // par le flow de login (LoginScreen, App, AuthContext) pour détecter le rôle.
      allow read: if isAuthenticated();

      // Écriture : admin uniquement
      allow create, update, delete: if isAdmin();
    }

    // =============================================
    // CONVERSATIONS & MESSAGES (Chat)
    // =============================================
    match /conversations/{clientId} {
      allow read, write: if isConsultant() || hasClientAccess(clientId);

      match /messages/{messageId} {
        allow read: if isConsultant() || hasClientAccess(clientId);
        allow create: if isConsultant() || hasClientAccess(clientId);
        // Les messages ne peuvent être ni modifiés ni supprimés
        allow update, delete: if false;
      }
    }

    // =============================================
    // ACTIVITIES COLLECTION (Audit Log)
    // =============================================
    match /activities/{activityId} {
      // Lecture : consultant OU client ayant accès au dossier concerné
      allow read: if isConsultant() || hasClientAccess(resource.data.clientId);

      // Création : tout utilisateur authentifié (logs d'audit, Cloud Functions inclus)
      allow create: if isAuthenticated();

      // Immuable : ne jamais modifier ou supprimer les logs d'audit
      allow update, delete: if false;
    }

    // =============================================
    // MAIL COLLECTION (Transactional Emails)
    // =============================================
    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // =============================================
    // APPOINTMENT TOKENS (Gestion RDV)
    // Accédés uniquement par les Cloud Functions (Admin SDK)
    // =============================================
    match /appointmentTokens/{tokenId} {
      allow read, write: if false;
    }

    // =============================================
    // CONSULTANT ALERTS (handoffs from AI chat, etc.)
    // =============================================
    match /consultantAlerts/{alertId} {
      // Read: consultants only (their inbox)
      allow read: if isConsultant();

      // Create: any authenticated user (clients trigger via AI chat handoff,
      // Cloud Functions can also write via Admin SDK bypass)
      allow create: if isAuthenticated();

      // Update: consultants only (to mark as resolved)
      allow update: if isConsultant();

      // Delete: admin only
      allow delete: if isAdmin();
    }

    // =============================================
    // DEFAULT: Deny everything else
    // =============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
